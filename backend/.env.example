# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/taskflow_pro

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_now_min_32_chars
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ─── File Upload ──────────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ─── Pagination ───────────────────────────────────────────────
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ─── App URL (used in responses) ──────────────────────────────
APP_URL=http://localhost:5000
